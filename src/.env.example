# ============================================================
# VARIÁVEIS DE AMBIENTE — CLÍNICA DOSAGEM
# ============================================================
# NUNCA commite o arquivo .env no Git!
# Este arquivo .env.example é o modelo — commite apenas ele.
# Copie para .env e preencha com seus valores reais.
# ============================================================

# Supabase — pegue em: supabase.com → seu projeto → Settings → API
REACT_APP_SUPABASE_URL=https://SEU_PROJETO.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# Ambiente: "development" ou "production"
REACT_APP_ENV=development
